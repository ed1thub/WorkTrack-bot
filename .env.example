# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=
# Random secret for webhook verification
TELEGRAM_SECRET_TOKEN=
# Your Telegram chat ID (use @userinfobot to find it)
ADMIN_CHAT_ID=
# Neon (or any PostgreSQL) connection string
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
# Hourly rate for payment calculations (default: 31.23)
HOURLY_RATE=31.23
# Optional: Google Sheets sync
SPREADSHEET_ID=
GOOGLE_CREDENTIALS_JSON=
# Optional: Vercel cron authentication secret
CRON_SECRET=
